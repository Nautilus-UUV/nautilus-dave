<?xml version="1.0"?>
<sdf version="1.7">
  <model name="glider_nautilus">

    <static>false</static>

    <!--           -->
    <!-- BASE LINK -->
    <!--           -->

    <link name="base_link">
      <inertial>

        <!-- Pose of the Centre of Mass in the NED base_link frame
             This comes from the Technical_Details spreadsheet (22.04.)
             without the contribution from ACU and oil mass -->

        <pose>0.066 0 0.013 0 0 0</pose>

        <!-- Moment of inertia matrix
             Taken around the Centre of Mass in the NED coordinate system.
             The values come from the HS25_Master_Assembly_Nautilus (as of 04.04.26)
             and contain the contributions of all parts except:
             * The moving parts of the Pitch ACU
             * The moving parts of the Roll ACU
             * The Blade of the rudder 
             Since the Onshape assmebly did likely not include the oil mass, it is not
             part of the moments of inertia matrix -->

        <inertia>
          <ixx>0.569665165</ixx>
          <ixy>0.014586839</ixy>
          <ixz>-0.135434148</ixz>
          <iyy>7.792</iyy>
          <iyz>0.003389589</iyz>
          <izz>7.738</izz>
        </inertia>

        <fluid_added_mass>
          <xx>5.30023995</xx>
          <yy>98.529516</yy>
          <zz>110.543023</zz>
          <pp>1.46943124</pp>
          <qq>20.2676439</qq>
          <rr>16.1139805</rr>
        </fluid_added_mass>

        <!-- Mass from the Technical_Details spreadsheet
             This does not include:
             * Movable ACU masses
             * Oil mass -->

        <mass>44.637</mass>
        
      </inertial>

      <visual name="base_link_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <!-- Model without wings and rudder. Frame corresponds to a NED 
                 coordinate system located at the geometric centre point of 
                 the hull shell cylinder. The mesh file below has
                 a coordinate system aligned with this convention -->
            <uri>model://meshes/glider_nautilus/nautilus_glider_nw_v04.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.7 0. 0 0.5</ambient>
          <diffuse>1 1 0 1</diffuse>
          <specular>0.7 0.7 0 0.5</specular>
        </material>
      </visual>

      <collision name="base_link_collision">
        <!-- This determines the buoyancy of the hull
             Specifically, this is the volume displaced by the hull shell and
             the two bulkheads when assembled into one geometric object. Looking
             at the geometry in the HS25_Master_Assembly_Nautilus, this should be
             about 0.054482 m^3.
             The NED coordinate system is at the geometric centre of the hull
             so the buoyancy forces from the hull coincide with the origin.
             The buoyancy plugin only supports collision geometries made of boxes
             and spheres. The volume is modelled as a box with a volume of about
             0.0544 m^3 centred at the origin. -->
        <pose>0.0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <!-- x y and z dimensions of the box (refers to base_link coordinates) -->
            <size>1.007723 0.232517 0.232517</size>  
          </box>
        </geometry>
      </collision>

      <!-- Box visualising where the bouyant volume of the
           hull is. Not functional, simply an optional sanity check. 
           Uncomment to show. -->
      <!-- <visual name="buoyancy_box">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>1.007723 0.232517 0.232517</size> 
          </box>
        </geometry>
        <material>
          <ambient>0 1 0 0.8</ambient>
          <diffuse>0 1 0 0.8</diffuse>
          <specular>0 1 0 0.8</specular>
        </material>
      </visual> -->

    </link>

    <plugin
      filename="gz-sim-hydrodynamics-system"
      name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      <water_density>1025.0</water_density>
      <!-- Added mass -->
      <xDotU>0</xDotU>
      <yDotV>0</yDotV>
      <zDotW>0</zDotW>
      <kDotP>0</kDotP>
      <mDotQ>0</mDotQ>
      <nDotR>0</nDotR>
      <!-- <xDotU>4</xDotU>
      <yDotV>95</yDotV>
      <zDotW>75</zDotW>
      <kDotP>0.4</kDotP>
      <mDotQ>27</mDotQ>
      <nDotR>32</nDotR> -->

      <!-- Linear Drag Coefficients -->
      <!-- diagonal terms -->
      <xU>-108</xU>
      <yV>-8</yV>
      <zW>-162</zW>
      <kP>-13</kP>
      <mQ>-32</mQ>
      <nR>-20</nR>
      <!-- cross terms -->
      <!-- <yR>150</yR>
      <zQ>-100</zQ>
      <mW>37</mW>
      <nV>-34</nV-->

      <!-- Quadratic Drag Coefficients -->
      <xUabsU>0</xUabsU>
      <yVabsV>0</yVabsV>
      <zWabsW>0</zWabsW>
      <kPabsP>0</kPabsP>
      <mQabsQ>0</mQabsQ>
      <nRabsR>0</nRabsR>
    </plugin>
    
    <!--              -->
    <!-- TRIMMING BOW -->
    <!--              -->

    <!-- A rigidly attached link providing the additional buoyancy
         or mass needed to make the glider float correctly -->

    <joint name="trimming_bow_joint" type="fixed">
      <pose>0.65 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>trimming_bow</child>0 0 0 
    </joint>

    <link name="trimming_bow">

      <pose>0.65 0 0 0 0 0</pose>
      
      <collision name="bow_trimming_foam_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.065 0.18 0.18</size>
          </box>
        </geometry>
      </collision>

      <visual name="bow_trimming_foam_visual">
        <geometry>
          <box>
            <size>0.065 0.15 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>0 0 1 0.8</ambient>
          <diffuse>0 0 1 0.8</diffuse>
          <specular>0 0 1 0.8</specular>
        </material>
      </visual>

    </link>

    <!--                -->
    <!-- TRIMMING STERN -->
    <!--                -->

    <!-- A rigidly attached link providing the additional buoyancy
         or mass needed to make the glider float correctly. Uncomment
         and add mass / a collision geometry to activate. -->

    <joint name="trimming_stern_joint" type="fixed">
      <pose>-0.7 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>trimming_stern</child> 
    </joint>

    <link name="trimming_stern">
      
      <collision name="stern_trimming_foam_collision">
        <geometry>
          <box>
            <size>0.015 0.18 0.18</size>
          </box>
        </geometry>
      </collision>

      <pose>-0.7 0 0 0 0 0</pose>

      <inertial>
        <mass>0.01</mass>
      </inertial>

      <visual name="stern_trimming_foam_visual">
        <geometry>
          <box>
            <size>0.015 0.18 0.18</size>
          </box>
        </geometry>
        <material>
          <ambient>0 0 1 0.8</ambient>
          <diffuse>0 0 1 0.8</diffuse>
          <specular>0 0 1 0.8</specular>
        </material>
      </visual>

    </link>

    <!--          -->
    <!-- LEFT FIN -->
    <!--          -->

    <link name="LeftFin_link">
      <!-- Frame for aerodynamic forces of left wing. 
           For now simply rest at base link -->
      
      <visual name="LeftFin_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://meshes/glider_nautilus/nautilus_glider_wing_l_v04.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 0.9</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

      <!-- The following visual element is for a sanity check on the 
           centre of pressure passed to the lift drag plugin. Insert 
           the same position in the pose tag. -->
      <visual name="centre_of_pressure_marker">
        <pose>-0.7 -0.408 0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.9 0 0 0.9</ambient>
          <diffuse>0.9 0 0 0.9</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

    </link>

    <joint name="LeftFin_joint" type="fixed">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>LeftFin_link</child>
    </joint>

    <plugin
      filename="gz-sim-lift-drag-system"
      name="gz::sim::systems::LiftDrag">
      <air_density>1025</air_density>
      <cla>4.13</cla> 
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0725</area>
      <upward>0 0 -1</upward>
      <forward>1 0 0</forward>
      <link_name>LeftFin_link</link_name>
      <!-- cp determines the centre of pressure in the link frame,
           i.e. wher the aerodynamic forces are applied -->
      <cp>-0.7 -0.408 0</cp>
    </plugin>

    <!--           -->
    <!-- RIGHT FIN -->
    <!--           -->

    <link name="RightFin_link">
      
      <visual name="RightFin_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://meshes/glider_nautilus/nautilus_glider_wing_r_v04.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 0.9</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

      <!-- The following visual element is for a sanity check on the 
           centre of pressure passed to the lift drag plugin. Insert 
           the same position in the pose tag. -->
      <visual name="centre_of_pressure_marker">
        <pose>-0.7 0.408  0 0 0 0</pose>  <!-- -1.205 0.408  0 0 0 0 -->
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0 0.9 0 0.9</ambient>
          <diffuse>0 0.9 0 0.9</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

    </link>

    <joint name="RightFin_joint" type="fixed">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>RightFin_link</child>
    </joint>

    <plugin
      filename="gz-sim-lift-drag-system"
      name="gz::sim::systems::LiftDrag">
      <air_density>1025</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0725</area>
      <upward>0 0 -1</upward>
      <forward>1 0 0</forward>
      <link_name>RightFin_link</link_name>
      <!-- cp determines the centre of pressure in the link frame,
           i.e. wher the aerodynamic forces are applied -->
      <cp>-0.7 0.408  0</cp>
    </plugin>
    
    <!--            -->
    <!-- TOP RUDDER -->
    <!--            -->

    <!-- Top rudder should be movable. First define this joint that
         the rudder's axis of rotation passes through -->

    <joint name="TopRudder_joint" type="fixed">
      <pose relative_to="base_link">-0.899156 0 -0.119 0 0 0</pose>
      <parent>base_link</parent>
      <child>TopRudder_link</child>
    </joint>

    <link name="TopRudder_link">

      <!-- Link (ie rudder body) has its coordinate system right
           on the rudder joint -->

      <pose relative_to="TopRudder_joint">0 0 0 0 0 0</pose>
      
      <!-- Integrates the mesh files of the rudder -->
      <visual name="Rudder_visual">
        <geometry>
          <mesh>
            <uri>model://meshes/glider_nautilus/nautilus_glider_rudder_v05.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 0.9</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

      <!-- The following visual element is for a sanity check on the 
           centre of pressure passed to the lift drag plugin. Insert 
           the same position in the pose tag. -->
      <visual name="centre_of_pressure_marker">
        <!-- Pose of the 'centre of pressure' in the local coordinates
             of the TopRudder_link, also a NED coordinate system -->
        <pose relative_to="TopRudder_link">-0.04 0 -0.1 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0 0 0.9 0.9</ambient>
          <diffuse>0 0 0.9 0.9</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

    </link>

    <!-- Started to implement a movable rudder -->

    <!-- <joint name="TopRudder_joint" type="revolute">
      <pose relative_to="base_link">0 1.404 0.119 0 0 0</pose>
      <parent>base_link</parent>
      <child>TopRudder_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
        <limit>
          <lower>-1</lower>
          <upper>1</upper>
        </limit>
      </axis>
    </joint> -->

    <!-- 0.5 was the initial set point of the PID position
     controller for the rudder -->

    <!-- <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>TopRudder_joint</joint_name>
      <initial_position>0.5</initial_position>
    </plugin> -->

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>TopRudder_joint</joint_name>
      <update_rate>2</update_rate>
    </plugin>

    <plugin
      filename="gz-sim-lift-drag-system"
      name="gz::sim::systems::LiftDrag">
      <air_density>1025</air_density>
      <cla>4.13</cla>
      <cla_stall>-1.1</cla_stall>
      <cda>0.2</cda>
      <cda_stall>0.03</cda_stall>
      <alpha_stall>0.17</alpha_stall>
      <a0>0</a0>
      <area>0.0244</area>
      <upward>0 1 0</upward>
      <forward>1 0 0</forward>
      <link_name>TopRudder_link</link_name>
      <cp>-0.04 0 -0.1</cp>
    </plugin>

    <!--         -->
    <!-- BLADDER -->
    <!--         -->

    <link name="bladder_link">
      <!-- Pose of bladder link in base link frame-->
      <pose>0.6 0 0 0 0 0</pose>
      <visual name="bladder_link_visual">
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 0.5</diffuse>
          <specular>0 0 1 0.5</specular>
        </material>
      </visual>
    </link>

    <joint name="bladder_joint" type="fixed">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>bladder_link</child>
    </joint>

    <!--          -->
    <!-- OIL MASS -->
    <!--          -->

    <link name="oil_weight_link">
      <!--Oil positioned in the middle between the 
      tank and the bladder. Static. Position in base_link coord-->
      <pose>0.4125 0 0.018 0 0 0</pose>
      <visual name="oil_weight_marker">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
      </visual>
      <inertial>
        <mass>2.185</mass>
      </inertial>
    </link>

    <joint name='oil_weight_joint' type='prismatic'>
      <pose>0.293 0 0.036 0 0 0</pose> <!--CHECK AXIS DEFINITION-->
      <parent>base_link</parent>
      <child>oil_weight_link</child>
      <axis>
        <xyz>0.9931947 0  -0.11646583</xyz>
        <limit>
          <lower>0</lower> <!-- Minimum position (in meters) -->
          <upper>0.3091</upper>  <!-- Maximum position (in meters) -->
          <!-- TODO Rate limiting for the movement of the joint-->
        </limit>
      </axis>
    </joint>

    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>oil_weight_joint</joint_name>
      <p_gain>10</p_gain>
    </plugin>

    <plugin
      filename="gz-sim-buoyancy-engine-system"
      name="gz::sim::systems::BuoyancyEngine">
      <link_name>bladder_link</link_name>
      <max_inflation_rate>0.0001</max_inflation_rate>
      <min_volume>0.0</min_volume>
      <max_volume>0.0025</max_volume>engine
      <neutral_volume>0.0</neutral_volume>
      <default_volume>0.00125</default_volume>
      <fluid_density>1025.0</fluid_density>
      <surface>0</surface>
      <namespace>glider_nautilus</namespace>
    </plugin>

    <!--     -->
    <!-- IMU -->
    <!--     -->

    <link name="imu_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <!-- <mass>0.015</mass> -->
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>50.0</update_rate>
        <topic>/model/glider_nautilus/imu</topic>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <!--         -->
    <!-- BATTERY -->
    <!--         -->

    <link name='battery_link'>
      <!-- Inertial properties of static battery accounted for in the
           inertial properties of the base link  -->
      <!-- <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-05</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-05</iyy>
          <iyz>0</iyz>
          <izz>1e-05</izz>
        </inertia>
      </inertial> -->
      <battery name='battery'>
        <voltage>4.2</voltage>
      </battery>
    </link>

    <joint name='battery_joint' type='fixed'>
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>battery_link</child>
    </joint>

    <!--     -->
    <!-- ACU -->
    <!--     -->

    <!-- PITCH ACU -->

    <link name='acu_tilt_link'>

      <!-- Pitch ACU weight starts in the middle -->
      <pose>-0.32525 0 -0.0438 0 0 0</pose>

      <inertial>
        <!-- <pose relative_to="acu_tilt_joint">0 0 0 0 0 0</pose> -->
        <mass>1.83</mass>
        <inertia>
          <ixx>1e-05</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-05</iyy>
          <iyz>0</iyz>
          <izz>1e-05</izz>
        </inertia>
      </inertial>

      <!-- Marker for debugging pitch ACU mass position -->
      <visual name="CM_pitch_ACU_marker">
        <!-- <pose relative_to="acu_tilt_joint">0 0 0 0 0 0</pose> -->
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.9 0 0 0.9</ambient>
          <diffuse>0.9 0 0 0.9</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>
    </link>

    <joint name='acu_tilt_joint' type='prismatic'>
      <!-- Updated according to spreadsheet on 22.04. -->
      <pose>-0.385 0 -0.0438 0 0 0</pose>
      <parent>base_link</parent>
      <child>acu_tilt_link</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <!-- Limits in the joints own coordinate system. Range is
               [-0.1195, 0] m: lower < upper as Gazebo expects, with the
               extended position at -0.1195 and the closed position at 0. -->
          <lower>-0.1195</lower> <!-- Minimum position (in meters) -->
          <upper>0</upper>       <!-- Maximum position (in meters) -->
          <effort>10.0</effort> <!-- Maximum effort (optional, in newton-meters) -->
          <velocity>0.5</velocity> <!-- Maximum velocity (optional, in meters/second) -->
        </limit>
      </axis>
    </joint>

    <!-- ROLL ACU -->

    <link name='acu_roll_link'>
      <pose>-0.428 0 0.034 0 0 0</pose>

      <inertial>
        <!-- Pose of the centre of mass relative to the pivot.
             From Onshape 22.04. -->
        <pose>0 0 0.027 0 0 0</pose>
        <!-- Mass of roll weight from spreadsheet as of 22.04. -->
        <mass>4.069</mass>
        <inertia>
          <ixx>1e-05</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-05</iyy>
          <iyz>0</iyz>
          <izz>1e-05</izz>
        </inertia>
      </inertial>
      <battery name='battery_acu_roll'>
        <voltage>4.2</voltage>
      </battery>

      <!-- Marker for debugging roll ACU mass position -->
      <visual name="CM_roll_ACU_marker">
        <pose>0 0 0.027 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.9 0 0 0.9</ambient>
          <diffuse>0.9 0 0 0.9</diffuse>
          <specular>0 0 0 0.9</specular>
        </material>
      </visual>

    </link>

    <joint name='acu_roll_joint' type='revolute'>
      <!-- Updated according to spreadsheet on 22.04. -->
      <pose>-0.428 0 0.034 0 0 0</pose> <!--Where the pivot is-->
      <parent>base_link</parent>
      <child>acu_roll_link</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-0.5236</lower> <!-- Minimum position (in radians) -->
          <upper>0.5236</upper>  <!-- Maximum position (in radians) -->
          <effort>10.0</effort> <!-- Maximum effort (optional, in newton-meters) -->
          <velocity>0.5</velocity> <!-- Maximum velocity (optional, in meters/second) -->
        </limit>
      </axis>
    </joint>

    <!-- ACU pitch (prismatic, 1.83 kg, range [-0.1195, 0] m).
         <topic> is mandatory here: the plugin's default
         "/model/<m>/joint/<j>/0/cmd_pos" has a path segment ("0") that
         starts with a digit, which ROS 2 topic-name validation rejects,
         so parameter_bridge cannot bridge it. The SDF therefore spells
         out the actual contract topic; this is not a "rebind for the
         bridge", it is the SDF *declaring* what name to use because
         the plugin default is unreachable from ROS.
         Gains tuned for the prismatic mass: defaults of p=1/i=0.1/d=0.01
         produce ~0.05 N for a 50 mm error, which is not enough to
         drive the joint within reasonable settling time. cmd_max/min
         clamp to the SDF effort limit. -->
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>acu_tilt_joint</joint_name>
      <topic>/model/glider_nautilus/joint/acu_tilt_joint/cmd_pos</topic>
      <p_gain>300</p_gain>
      <i_gain>0</i_gain>
      <d_gain>30</d_gain>
      <cmd_max>10</cmd_max>
      <cmd_min>-10</cmd_min>
    </plugin>

    <!-- ACU roll (revolute, 4.069 kg link with 27 mm CoM offset,
         range [-0.5236, 0.5236] rad). Same <topic> rationale as
         acu_tilt_joint above. Effective rotational inertia
         ~3e-3 kg·m²; gains scaled to the smaller inertia and ±0.5 rad
         command range. -->
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>acu_roll_joint</joint_name>
      <topic>/model/glider_nautilus/joint/acu_roll_joint/cmd_pos</topic>
      <p_gain>50</p_gain>
      <i_gain>0</i_gain>
      <d_gain>5</d_gain>
      <cmd_max>10</cmd_max>
      <cmd_min>-10</cmd_min>
    </plugin>

    <plugin
      filename="gz-sim-linearbatteryplugin-system"
      name="gz::sim::systems::LinearBatteryPlugin">
      <battery_name>battery</battery_name>
      <voltage>4.2</voltage>
      <open_circuit_voltage_constant_coef>3.7</open_circuit_voltage_constant_coef>
      <open_circuit_voltage_linear_coef>-3.1424</open_circuit_voltage_linear_coef>
      <initial_charge>4.32</initial_charge>
      <capacity>4.8</capacity>
      <resistance>0.002</resistance>
      <smooth_current_tau>1.9499</smooth_current_tau>
      <enable_recharge>false</enable_recharge>
      <power_load>10</power_load>
      <start_on_motion>true</start_on_motion>
    </plugin>

    <!--        -->
    <!-- NAVSAT -->
    <!--        -->

    <link name="navsat_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <sensor name="navsat_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>30.0</update_rate>
        <topic>/model/glider_nautilus/navsat</topic>
      </sensor>
    </link>

    <joint name="navsat_joint" type="fixed">
      <pose>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>navsat_link</child>
    </joint>

    <plugin
      filename="gz-sim-navsat-system"
      name="gz::sim::systems::NavSat">
    </plugin>

    <!--               -->
    <!-- OTHER PLUGINS -->
    <!--               -->

    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>map</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <dimensions>3</dimensions>
      <odom_publish_frequency>100</odom_publish_frequency>
    </plugin>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>

    <!-- Sea Pressure Sensor Plugin -->
    <plugin
      filename="sea_pressure_sensor"
      name=" dave_gz_sensor_plugins::SubseaPressureSensorPlugin">
      <namespace>glider_nautilus</namespace>
      <topic>sea_pressure</topic>
      <update_rate>10</update_rate>
      <noise_sigma>3.0</noise_sigma>
      <estimate_depth_on>true</estimate_depth_on>
      <standard_pressure>101.325</standard_pressure>
      <kPa_per_meter>9.80638</kPa_per_meter>
    </plugin>

  </model>
</sdf>
